<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/appBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:background="?attr/appSurface">
        <ImageView android:id="@+id/btnBack" android:layout_width="32dp" android:layout_height="32dp"
            android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_back" android:padding="4dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Панель администратора"
            android:textSize="18sp" android:textStyle="bold"
            android:textColor="?attr/appTextPrimary" android:layout_marginStart="12dp"/>
        <TextView android:id="@+id/tvAdminBadge" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="ADMIN"
            android:textSize="11sp" android:textColor="@android:color/white"
            android:background="@color/priority_high" android:padding="4dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊 Статистика системы" android:textSize="16sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary" android:layout_marginBottom="12dp"/>

            <!-- Row 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="?attr/appSurface" android:padding="12dp"
                    android:gravity="center" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvTotalUsers" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/purple_500"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👥 Юзеров" android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="?attr/appSurface" android:padding="12dp"
                    android:gravity="center" android:layout_marginHorizontal="2dp">
                    <TextView android:id="@+id/tvTotalTasks" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/priority_low"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📝 Задач" android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="?attr/appSurface" android:padding="12dp"
                    android:gravity="center" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvCompleted" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="#22C55E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅ Готово" android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="?attr/appSurface" android:padding="12dp"
                    android:gravity="center" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvHabits" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="#45B7D1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥 Привычек" android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="?attr/appSurface" android:padding="12dp"
                    android:gravity="center" android:layout_marginHorizontal="2dp">
                    <TextView android:id="@+id/tvMoods" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="#F59E0B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😊 Настр." android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="?attr/appSurface" android:padding="12dp"
                    android:gravity="center" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvCompletedToday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="#FF6B6B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡ Сегодня" android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Progress bar of completion -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="?attr/appSurface"
                android:padding="12dp" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/tvCompletionLabel" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Процент выполнения: 0%"
                    android:textSize="13sp" android:textColor="?attr/appTextPrimary"
                    android:layout_marginBottom="6dp"/>
                <ProgressBar android:id="@+id/progressCompletion" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="10dp"
                    android:max="100" android:progress="0" android:progressTint="#22C55E"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏆 Таблица лидеров" android:textSize="16sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary" android:layout_marginBottom="8dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvLeaderboard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥 Управление пользователями" android:textSize="16sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary" android:layout_marginBottom="8dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvUsers"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
