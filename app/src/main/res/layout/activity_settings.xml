<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/appBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp"
        android:background="?attr/appSurface">
        <ImageView android:id="@+id/btnBack" android:layout_width="32dp" android:layout_height="32dp"
            android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_back" android:padding="4dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Настройки" android:textSize="20sp" android:textStyle="bold"
            android:layout_marginStart="12dp" android:textColor="?attr/appTextPrimary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical"
        android:background="?attr/appSurface" android:layout_marginTop="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Тёмная тема" android:textSize="16sp" android:textColor="?attr/appTextPrimary"/>
        <Switch android:id="@+id/switchDarkTheme" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical"
        android:background="?attr/appSurface" android:layout_marginTop="1dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Напоминание о настроении (21:00)" android:textSize="16sp" android:textColor="?attr/appTextPrimary"/>
        <Switch android:id="@+id/switchMoodNotif" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="?attr/appTextPrimary" android:alpha="0.08" android:layout_marginTop="24dp"/>
    <Button android:id="@+id/btnTrash" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="🗑 Корзина" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp" android:textColor="@android:color/white"
        android:backgroundTint="#7C4DFF" style="@style/Widget.MaterialComponents.Button"/>
    <Button android:id="@+id/btnCategories" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="📁 Управление папками" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp" android:textColor="@android:color/white"
        android:backgroundTint="#4ECDC4" style="@style/Widget.MaterialComponents.Button"/>
    <Button android:id="@+id/btnAdmin" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="⚙️ Панель администратора" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp" android:textColor="@android:color/white"
        android:backgroundTint="#FF6B6B" android:visibility="gone" style="@style/Widget.MaterialComponents.Button"/>
    <Button android:id="@+id/btnLogout" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Выйти из аккаунта" android:layout_margin="16dp"
        android:backgroundTint="#EF4444" android:textColor="@android:color/white"
        style="@style/Widget.MaterialComponents.Button"/>
</LinearLayout>
