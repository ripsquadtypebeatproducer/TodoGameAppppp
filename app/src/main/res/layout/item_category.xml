<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@drawable/bg_card_minimal"
    android:padding="14dp" android:layout_marginBottom="8dp" android:gravity="center_vertical">
    <View android:id="@+id/categoryColorDot" android:layout_width="16dp" android:layout_height="16dp"
        android:background="@color/purple_500" android:layout_marginEnd="12dp"/>
    <TextView android:id="@+id/tvCategoryName" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="16sp" android:textColor="?attr/appTextPrimary"/>
    <ImageView android:id="@+id/btnDeleteCategory" android:layout_width="32dp"
        android:layout_height="32dp" android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_delete"
        android:padding="4dp" android:alpha="0.5"/>
</LinearLayout>
