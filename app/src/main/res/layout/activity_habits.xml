<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/appBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp"
        android:background="?attr/appSurface">
        <ImageView android:id="@+id/btnBack" android:layout_width="32dp" android:layout_height="32dp"
            android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_back" android:padding="4dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Привычки" android:textSize="20sp"
            android:textStyle="bold" android:layout_marginStart="12dp" android:textColor="?attr/appTextPrimary"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvHabits"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:padding="16dp" android:clipToPadding="false"/>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddHabit" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="end"
        android:layout_margin="16dp" android:src="@drawable/ic_add_line"
        app:backgroundTint="@color/purple_500"/>
</LinearLayout>
