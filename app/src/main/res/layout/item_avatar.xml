<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="8dp" android:gravity="center">
    <FrameLayout android:layout_width="64dp" android:layout_height="64dp">
        <com.todogame.app.views.AvatarView android:id="@+id/avatarView"
            android:layout_width="64dp" android:layout_height="64dp"/>
        <!-- Замок для покупных, ещё не купленных -->
        <ImageView android:id="@+id/ivLock"
            android:layout_width="22dp" android:layout_height="22dp"
            android:layout_gravity="center" android:src="@drawable/ic_lock"
            android:tint="@color/white" android:visibility="gone"/>
    </FrameLayout>
</LinearLayout>
