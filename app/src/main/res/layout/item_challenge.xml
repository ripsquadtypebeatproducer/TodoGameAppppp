<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@drawable/bg_card_minimal"
    android:layout_marginBottom="10dp" android:padding="16dp" android:gravity="center_vertical">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvChallengeDesc" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="15sp"
            android:textColor="?attr/appTextPrimary" android:textStyle="bold"/>
        <ProgressBar android:id="@+id/challengeProgressBar" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp"
            android:layout_marginTop="8dp" android:progressTint="@color/purple_500"/>
        <TextView android:id="@+id/tvChallengeProgress" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:layout_marginTop="4dp"/>
    </LinearLayout>
    <ImageView android:id="@+id/ivChallengeDone" android:layout_width="32dp" android:layout_height="32dp"
        android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_star_filled" android:layout_marginStart="12dp" android:visibility="gone"/>
</LinearLayout>
