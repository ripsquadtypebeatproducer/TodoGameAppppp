<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:paddingHorizontal="40dp" android:background="?attr/appBackground">

    <!-- Icon circle -->
    <FrameLayout android:layout_width="100dp" android:layout_height="100dp"
        android:layout_marginBottom="36dp">
        <View android:layout_width="100dp" android:layout_height="100dp"
            android:background="?attr/appSurface2"/>
        <ImageView android:id="@+id/ivOnboardIcon"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_star_filled"
            android:tint="@color/purple_200"/>
    </FrameLayout>

    <TextView android:id="@+id/tvTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="26sp" android:textStyle="bold" android:gravity="center"
        android:textColor="?attr/appTextPrimary" android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvDesc"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="15sp" android:gravity="center" android:lineSpacingMultiplier="1.6"
        android:textColor="?attr/appTextSecondary"/>
</LinearLayout>
