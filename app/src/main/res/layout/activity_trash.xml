<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/appBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:background="?attr/appSurface">
        <ImageView android:id="@+id/btnBack" android:layout_width="32dp" android:layout_height="32dp"
            android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_back" android:padding="4dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Корзина" android:textSize="20sp" android:textStyle="bold"
            android:textColor="?attr/appTextPrimary" android:layout_marginStart="12dp"/>
        <Button android:id="@+id/btnClearAll" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="Очистить"
            android:backgroundTint="@color/priority_high" android:textColor="@android:color/white"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>
    <TextView android:id="@+id/tvEmpty" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:text="Корзина пуста"
        android:gravity="center" android:textSize="16sp"
        android:textColor="?attr/appTextSecondary" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvTrash"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:padding="12dp" android:clipToPadding="false"/>
</LinearLayout>
