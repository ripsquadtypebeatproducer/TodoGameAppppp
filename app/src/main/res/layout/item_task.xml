<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_minimal"
    android:layout_marginBottom="@dimen/card_margin"
    android:paddingHorizontal="16dp" android:paddingVertical="14dp"
    android:gravity="center_vertical">

    <!-- Круглый чекбокс с цветом приоритета -->
    <ImageButton android:id="@+id/btnComplete"
        android:layout_width="24dp" android:layout_height="24dp"
        android:background="@drawable/bg_check_circle"
        android:scaleType="centerInside"
        android:src="@android:color/transparent"
        android:layout_marginEnd="14dp"/>

    <!-- Контент -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvTaskTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="15sp" android:textStyle="bold"
            android:textColor="?attr/appTextPrimary"/>
        <TextView android:id="@+id/tvTaskDescription"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="?attr/appTextSecondary"
            android:maxLines="1" android:ellipsize="end" android:layout_marginTop="3dp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="5dp"
            android:gravity="center_vertical">
            <TextView android:id="@+id/tvCategory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="@color/purple_500"
                android:layout_marginEnd="10dp"/>
            <TextView android:id="@+id/tvDueDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="?attr/appTextSecondary"/>
            <!-- Бейдж "от друга" для совместных задач -->
            <TextView android:id="@+id/tvSharedBadge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="@color/purple_500"
                android:layout_marginStart="8dp" android:visibility="gone"
                android:paddingHorizontal="8dp" android:paddingVertical="2dp"
                android:background="@drawable/bg_pill"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Удалить (приглушённая, по умолчанию скрыта визуально) -->
    <ImageButton android:id="@+id/btnDelete"
        android:layout_width="32dp" android:layout_height="32dp"
        android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_close"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="6dp" android:alpha="0.3"/>
</LinearLayout>
