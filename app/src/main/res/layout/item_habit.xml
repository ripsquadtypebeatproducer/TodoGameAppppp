<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_card_minimal"
    android:layout_marginBottom="12dp" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <View android:id="@+id/habitColorBar" android:layout_width="4dp" android:layout_height="40dp"
            android:layout_marginEnd="12dp" android:background="@color/purple_500"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvHabitName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary"/>
            <TextView android:id="@+id/tvHabitStreak" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="@color/priority_medium" android:layout_marginTop="2dp"/>
            <TextView android:id="@+id/tvHabitTotal" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="?attr/appTextPrimary" android:alpha="0.5"/>
        </LinearLayout>
        <Button android:id="@+id/btnLogHabit" android:layout_width="80dp" android:layout_height="36dp"
            android:text="Готово" android:textSize="12sp"
            android:backgroundTint="@color/purple_500" android:textColor="@android:color/white"
            style="@style/Widget.MaterialComponents.Button" android:layout_marginEnd="8dp"/>
        <ImageView android:id="@+id/btnDeleteHabit" android:layout_width="32dp" android:layout_height="32dp"
            android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_delete" android:padding="4dp" android:alpha="0.5"/>
    </LinearLayout>
    <GridLayout android:id="@+id/heatmapGrid" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="12dp"
        android:columnCount="13"/>
</LinearLayout>
