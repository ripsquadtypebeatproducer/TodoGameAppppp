<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/appBackground"
    android:padding="20dp">

    <!-- Заголовок -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <ImageView android:id="@+id/btnBack"
            android:layout_width="28dp" android:layout_height="28dp"
            android:src="@drawable/ic_back" android:tint="?attr/appTextPrimary"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Друзья"
            android:textSize="22sp" android:textStyle="bold"
            android:textColor="?attr/appTextPrimary" android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Поиск -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp">
        <EditText android:id="@+id/etSearch"
            android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
            android:hint="Найти по имени..." android:textColorHint="?attr/appTextSecondary"
            android:textColor="?attr/appTextPrimary" android:textSize="14sp"
            android:background="@drawable/bg_card_minimal" android:paddingHorizontal="16dp"/>
        <Button android:id="@+id/btnSearch"
            android:layout_width="wrap_content" android:layout_height="46dp"
            android:text="Найти" android:textColor="@color/white" android:textSize="13sp"
            android:background="@drawable/bg_button_accent"
            android:paddingHorizontal="18dp" android:layout_marginStart="8dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <!-- Вкладки -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp">
        <TextView android:id="@+id/tabFriends"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Мои друзья" android:gravity="center" android:textSize="13sp"
            android:textStyle="bold" android:textColor="@color/purple_500" android:padding="10dp"/>
        <TextView android:id="@+id/tabRequests"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Заявки" android:gravity="center" android:textSize="13sp"
            android:textColor="?attr/appTextSecondary" android:padding="10dp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvEmpty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Пока никого нет" android:gravity="center"
        android:textColor="?attr/appTextSecondary" android:textSize="13sp"
        android:padding="20dp" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvFriends"
        android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>
