<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="?attr/appBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Top bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/btnBack" android:layout_width="32dp" android:layout_height="32dp"
                android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_back"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Профиль" android:textSize="20sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary" android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Avatar + info card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/bg_card"
            android:padding="16dp" android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <FrameLayout android:layout_width="72dp" android:layout_height="72dp">
                <com.todogame.app.views.AvatarView android:id="@+id/profileAvatarView"
                    android:layout_width="72dp" android:layout_height="72dp"/>
                <View android:id="@+id/btnEditAvatar" android:layout_width="72dp" android:layout_height="72dp"/>
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                <TextView android:id="@+id/tvProfileUsername" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="?attr/appTextPrimary"/>
                <TextView android:id="@+id/tvProfileEmail" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="13sp"
                    android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:layout_marginTop="2dp"/>
                <TextView android:id="@+id/tvProfileRole" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="11sp"
                    android:textColor="@color/white" android:paddingHorizontal="10dp" android:paddingVertical="3dp"
                    android:background="@drawable/bg_button_accent"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stats grid -->
        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="3" android:layout_marginBottom="16dp" android:useDefaultMargins="true">
            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@drawable/bg_card" android:padding="12dp" android:gravity="center"
                android:layout_margin="4dp">
                <TextView android:id="@+id/tvTasksCompleted" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="@color/purple_500"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Задач выполнено" android:textSize="11sp"
                    android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:gravity="center"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@drawable/bg_card" android:padding="12dp" android:gravity="center"
                android:layout_margin="4dp">
                <TextView android:id="@+id/tvStreakCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="@color/priority_medium"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Серия дней 🔥" android:textSize="11sp"
                    android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:gravity="center"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@drawable/bg_card" android:padding="12dp" android:gravity="center"
                android:layout_margin="4dp">
                <TextView android:id="@+id/tvAchievementsCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="@color/priority_low"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Достижений" android:textSize="11sp"
                    android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:gravity="center"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@drawable/bg_card" android:padding="12dp" android:gravity="center"
                android:layout_margin="4dp">
                <TextView android:id="@+id/tvTasksActive" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="@color/priority_high"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Активных задач" android:textSize="11sp"
                    android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:gravity="center"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@drawable/bg_card" android:padding="12dp" android:gravity="center"
                android:layout_margin="4dp">
                <TextView android:id="@+id/tvMoodLogsCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="@color/mood_4"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Записей настроения" android:textSize="11sp"
                    android:textColor="?attr/appTextPrimary" android:alpha="0.6" android:gravity="center"/>
            </LinearLayout>
        </GridLayout>

        <!-- Навигация к новым разделам -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Разделы" android:textSize="16sp" android:textStyle="bold"
            android:textColor="?attr/appTextPrimary" android:layout_marginBottom="10dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:id="@+id/navPet" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_card_minimal" android:padding="16dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🦊" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Питомец" android:textSize="12sp" android:textColor="?attr/appTextSecondary"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/navStats" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_card_minimal" android:padding="16dp" android:layout_marginStart="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Статистика" android:textSize="12sp" android:textColor="?attr/appTextSecondary"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <LinearLayout android:id="@+id/navShop" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_card_minimal" android:padding="16dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🛍️" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Магазин" android:textSize="12sp" android:textColor="?attr/appTextSecondary"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/navFriends" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_card_minimal" android:padding="16dp" android:layout_marginStart="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👥" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Друзья" android:textSize="12sp" android:textColor="?attr/appTextSecondary"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Mood chart -->
        <TextView android:id="@+id/tvMoodChartLabel" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Настроение за 30 дней"
            android:textSize="16sp" android:textStyle="bold" android:textColor="?attr/appTextPrimary"
            android:layout_marginBottom="8dp" android:visibility="gone"/>
        <com.todogame.app.activities.MoodChartView android:id="@+id/moodChartView"
            android:layout_width="match_parent" android:layout_height="150dp"
            android:background="@drawable/bg_card" android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- Achievements -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Достижения" android:textSize="16sp" android:textStyle="bold"
            android:textColor="?attr/appTextPrimary" android:layout_marginBottom="8dp"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvAchievements"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</ScrollView>
