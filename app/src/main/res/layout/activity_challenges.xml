<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/appBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp"
        android:background="?attr/appSurface">
        <ImageView android:id="@+id/btnBack" android:layout_width="32dp" android:layout_height="32dp"
            android:tint="?attr/appTextSecondary"
        android:src="@drawable/ic_back" android:padding="4dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Вызовы дня" android:textSize="20sp" android:textStyle="bold"
            android:layout_marginStart="12dp" android:textColor="?attr/appTextPrimary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp" android:background="?attr/appSurface"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tvChallengeStatus" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="16sp"
            android:textColor="@color/purple_500" android:textStyle="bold"/>
        <TextView android:id="@+id/tvStarEarned" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="18sp"
            android:textColor="@color/priority_medium" android:visibility="gone" android:layout_marginTop="4dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvChallenges"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:padding="16dp" android:clipToPadding="false"/>
</LinearLayout>
